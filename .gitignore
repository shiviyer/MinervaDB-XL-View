# =============================================================================
# .gitignore
# Excel-PostgreSQL-Dashboard Repository
# =============================================================================

# ---- SECURITY: Never commit credentials ----
config/config.ini
config/.env
.env
.env.*
!.env.example
config/.encryption_key
*.key
*.pem
*.p12
*.pfx

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
*.pyo

# ---- Virtual Environments ----
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/
.python-version

# ---- Excel & Office Files (exclude binary templates from tracking) ----
# Comment out if you want to track your Excel templates
*.xlsx
*.xlsm
*.xlsb
*.xls
*.xlam
# Exception: keep example/template files with _template suffix
!templates/*_template.xlsx

# ---- Logs ----
logs/
*.log
*.log.*
log/

# ---- OS Generated ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# ---- Windows ----
$RECYCLE.BIN/
*.lnk

# ---- Testing & Coverage ----
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ---- Distribution / Packaging ----
dist/
build/
*.whl

# ---- Jupyter Notebooks ----
.ipynb_checkpoints
*.ipynb

# ---- Documentation builds ----
docs/_build/
site/

# ---- Temporary files ----
tmp/
temp/
*.tmp
*.bak
*.backup
*.orig
*.swp

# ---- Database dumps (never commit) ----
*.dump
*.sql.gz
*.pg_dump

# ---- Output files ----
output/
exports/
reports/
